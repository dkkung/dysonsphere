---
// Renders a dysonsphere Vega-Lite spec live and interactive via vega-embed.
// `name` is the basename of a spec in public/charts/ (generated by scripts/gen_examples.py).
interface Props {
	name: string;
	alt?: string;
}
const { name, alt = 'dysonsphere chart' } = Astro.props;
const src = `${import.meta.env.BASE_URL}charts/${name}.json`;
---

<figure class="ds-chart">
	<div class="ds-chart__view" data-vega-src={src} role="img" aria-label={alt}></div>
</figure>

<script>
	import vegaEmbed from 'vega-embed';

	function render() {
		document.querySelectorAll<HTMLElement>('.ds-chart__view[data-vega-src]').forEach(async (el) => {
			if (el.dataset.rendered) return;
			const src = el.dataset.vegaSrc;
			if (!src) return;
			el.dataset.rendered = '1';
			try {
				const spec = await (await fetch(src)).json();
				await vegaEmbed(el, spec, { actions: true, renderer: 'svg' });
			} catch (e) {
				el.textContent = 'Failed to load chart.';
				console.error(e);
			}
		});
	}

	render();
	// Starlight navigates with view transitions; re-render on client-side page loads.
	document.addEventListener('astro:page-load', render);
</script>

<style>
	.ds-chart {
		margin: 1.25rem 0;
	}
	.ds-chart__view {
		display: flex;
		justify-content: center;
		background: #fff;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		padding: 1rem;
		overflow: auto;
	}
</style>
