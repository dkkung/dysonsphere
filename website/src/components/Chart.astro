---
// Renders a dysonsphere Vega-Lite spec live and interactive via vega-embed.
// `name` maps to public/charts/<name>-light.json and <name>-dark.json (generated by
// scripts/gen_examples.py). The matching variant is shown for the site's theme and swapped
// live on toggle; the background is transparent so the page provides contrast.
interface Props {
	name: string;
	alt?: string;
	/** Apply the save()-time inward-ticks SVG fix (theme(inwardTicks=True) charts). */
	inwardTicks?: boolean;
	/** Auto-zoom the render to fill its container's width (for size-matched comparisons). */
	fitWidth?: boolean;
}
const { name, alt = 'dysonsphere chart', inwardTicks = false, fitWidth = false } = Astro.props;
---

<figure class="ds-chart">
	<div
		class="ds-chart__view"
		data-chart={name}
		data-inward={inwardTicks ? '1' : undefined}
		data-fit={fitWidth ? '1' : undefined}
		role="img"
		aria-label={alt}
	>
	</div>
</figure>

<script>
	import vegaEmbed from 'vega-embed';
	import { fixSuperscripts, flipTicksInward } from '../lib/fixSuperscripts';

	const BASE = import.meta.env.BASE_URL;
	const views = new WeakMap<HTMLElement, { finalize: () => void }>();

	async function renderOne(el: HTMLElement) {
		const name = el.dataset.chart;
		if (!name) return;
		const theme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
		try {
			const spec = await (await fetch(`${BASE}charts/${name}-${theme}.json`)).json();
			views.get(el)?.finalize();
			el.innerHTML = '';
			// A spec that bakes its own background (chartFill comparisons, the default-theme
			// example) keeps it; everything else renders transparent so the page shows through.
			const opaque = Boolean(spec.background ?? spec.config?.background);
			views.set(
				el,
				await vegaEmbed(el, spec, {
					actions: true,
					renderer: 'svg',
					...(opaque ? {} : { background: 'transparent' }),
				}),
			);
			fixSuperscripts(el);
			if (el.dataset.inward) flipTicksInward(el);
			if (el.dataset.fit) {
				// Chart.astro embeds with actions:true, so the .chart-wrapper exists and the
				// site-wide zoom rule reads the variable - override it with the computed fit.
				// Measure the block-level <figure>, NOT the embed container: vega-embed sizes
				// the container to its (already-zoomed) content, which would feed back.
				const svg = el.querySelector('svg');
				const natural = svg ? parseFloat(svg.getAttribute('width') ?? '0') : 0;
				const avail = el.closest('figure')?.clientWidth ?? 0;
				if (natural > 0 && avail > 0) {
					el.style.setProperty('--ds-chart-zoom', (avail / natural).toFixed(3));
				}
			}
		} catch (e) {
			el.textContent = 'Failed to load chart.';
			console.error(e);
		}
	}

	function renderAll() {
		document.querySelectorAll<HTMLElement>('.ds-chart__view[data-chart]').forEach((el) => renderOne(el));
	}

	renderAll();
	// Re-render on client-side navigation (view transitions) and on the light/dark toggle.
	document.addEventListener('astro:page-load', renderAll);
	new MutationObserver(renderAll).observe(document.documentElement, {
		attributes: true,
		attributeFilter: ['data-theme'],
	});
</script>

<style>
	.ds-chart {
		margin: 1.25rem 0;
	}
	.ds-chart__view {
		display: flex;
		justify-content: center;
		padding: 0.5rem 0;
		overflow: auto;
	}
</style>
