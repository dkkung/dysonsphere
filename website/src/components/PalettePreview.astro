---
// Live palette preview: six charts (a diagonal ramp surface, categorical bars/scatter/lines, a
// binned heatmap, and a Gaussian-mixture density surface) that re-render with whichever palette
// is selected in the <Palettes /> browser below - the same idea as the old gallery's "same
// charts over several palettes", but interactive.
//
// Mechanics: the base specs are the generated preview_* charts (authored against the default
// theme, no baked colors); on selection we patch the spec's `config.range` client-side - the
// bare `category` array for nominal scales (positional, like the library), `{scheme: [...]}`
// for the continuous surfaces (ramp/heatmap/density) - and re-embed. Sequential/diverging
// palettes are sampled to the series count exactly like `ds.palette(name, n)`; qualitative
// palettes pass through as-is. Listens for the `ds-palette-select` CustomEvent dispatched by
// Palettes.astro. The default selection is whatever palette comes FIRST in the generated list
// (baked server-side for the label, seeded client-side from the first swatch).
import palettes from '../generated/palettes.json';
const firstPalette = palettes[0].name;
---

<div class="palprev not-content">
	<div class="palprev__bar">
		<button id="palprev-copy-name" class="palprev__btn" title="Copy the selected palette's name">
			copy name
		</button>
		<button id="palprev-copy" class="palprev__btn" title="Copy the selected palette's hex codes">
			copy hex codes
		</button>
		{/* Starlight's own theme iconography (sun/moon); the active mode's icon shows. */}
		<button
			id="palprev-theme"
			class="palprev__btn palprev__theme"
			data-mode="light"
			aria-label="Preview theme"
			title="Preview theme (temporary - leaving the page restores your setting)"
		>
			<svg data-icon="light" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
				<path d="M5 12a1 1 0 0 0-1-1H3a1 1 0 0 0 0 2h1a1 1 0 0 0 1-1Zm.64 5-.71.71a1 1 0 0 0 0 1.41 1 1 0 0 0 1.41 0l.71-.71A1 1 0 0 0 5.64 17ZM12 5a1 1 0 0 0 1-1V3a1 1 0 0 0-2 0v1a1 1 0 0 0 1 1Zm5.66 2.34a1 1 0 0 0 .7-.29l.71-.71a1 1 0 1 0-1.41-1.41l-.66.71a1 1 0 0 0 0 1.41 1 1 0 0 0 .66.29Zm-12-.29a1 1 0 0 0 1.41 0 1 1 0 0 0 0-1.41l-.71-.71a1.004 1.004 0 1 0-1.43 1.41l.73.71ZM21 11h-1a1 1 0 0 0 0 2h1a1 1 0 0 0 0-2Zm-2.64 6A1 1 0 0 0 17 18.36l.71.71a1 1 0 0 0 1.41 0 1 1 0 0 0 0-1.41l-.76-.66ZM12 6.5a5.5 5.5 0 1 0 5.5 5.5A5.51 5.51 0 0 0 12 6.5Zm0 9a3.5 3.5 0 1 1 0-7 3.5 3.5 0 0 1 0 7Zm0 3.5a1 1 0 0 0-1 1v1a1 1 0 0 0 2 0v-1a1 1 0 0 0-1-1Z"></path>
			</svg>
			<svg data-icon="dark" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
				<path d="M21.64 13a1 1 0 0 0-1.05-.14 8.049 8.049 0 0 1-3.37.73 8.15 8.15 0 0 1-8.14-8.1 8.59 8.59 0 0 1 .25-2A1 1 0 0 0 8 2.36a10.14 10.14 0 1 0 14 11.69 1 1 0 0 0-.36-1.05Zm-9.5 6.69A8.14 8.14 0 0 1 7.08 5.22v.27a10.15 10.15 0 0 0 10.14 10.14 9.784 9.784 0 0 0 2.1-.22 8.11 8.11 0 0 1-7.18 4.32v-.04Z"></path>
			</svg>
		</button>
		{/* Colorblindness simulator: an feColorMatrix (Machado 2009, severity 1.0) applied to the
		    swatches AND the live preview charts, so a palette can be judged under each deficiency. */}
		<select id="palprev-cvd" class="palprev__btn" title="Simulate color vision deficiency">
			<option value="">normal vision</option>
			<option value="deuteranopia">deuteranopia</option>
			<option value="protanopia">protanopia</option>
			<option value="tritanopia">tritanopia</option>
		</select>
	</div>
	<svg width="0" height="0" style="position: absolute" aria-hidden="true">
		<filter id="cvd-deuteranopia" color-interpolation-filters="linearRGB">
			<feColorMatrix type="matrix" values="0.367322 0.860646 -0.227968 0 0  0.280085 0.672501 0.047413 0 0  -0.011820 0.042940 0.968881 0 0  0 0 0 1 0" />
		</filter>
		<filter id="cvd-protanopia" color-interpolation-filters="linearRGB">
			<feColorMatrix type="matrix" values="0.152286 1.052583 -0.204868 0 0  0.114503 0.786281 0.099216 0 0  -0.003882 0.048116 0.955765 0 0  0 0 0 1 0" />
		</filter>
		<filter id="cvd-tritanopia" color-interpolation-filters="linearRGB">
			<feColorMatrix type="matrix" values="1.255528 -0.076749 -0.178779 0 0  -0.078411 0.930809 0.147602 0 0  0.004733 0.691367 0.303900 0 0  0 0 0 1 0" />
		</filter>
	</svg>
	<p class="palprev__status">Previewing <code id="palprev-name">{firstPalette}</code></p>
	<div class="palprev__row">
		<div class="palprev__chart" data-preview="preview_ramp" data-role="heatmap"></div>
		<div class="palprev__chart" data-preview="preview_bars" data-role="category" data-n="6"></div>
		<div class="palprev__chart" data-preview="preview_scatter" data-role="heatmap"></div>
		<div class="palprev__chart" data-preview="preview_lines" data-role="category" data-n="5"></div>
		<div class="palprev__chart" data-preview="preview_heatmap" data-role="heatmap"></div>
		<div class="palprev__chart" data-preview="preview_density" data-role="heatmap"></div>
	</div>
</div>

<script>
	import vegaEmbed from 'vega-embed';

	const BASE = import.meta.env.BASE_URL;
	const specCache = new Map<string, Promise<any>>();
	const views = new WeakMap<HTMLElement, { finalize: () => void }>();
	// Natural (unzoomed) svg width per chart; the applied zoom is the minimum shared fit.
	const naturals = new Map<HTMLElement, number>();

	let current: { name: string; kind: string; colors: string[] } = {
		name: '', // seeded from the first swatch in the palette browser (see boot)
		kind: 'sequential',
		colors: [],
	};

	function fetchSpec(name: string, theme: string): Promise<any> {
		const key = `${name}-${theme}`;
		if (!specCache.has(key)) {
			specCache.set(
				key,
				fetch(`${BASE}charts/${key}.json`).then((r) => r.json()),
			);
		}
		return specCache.get(key)!;
	}

	/** n evenly spaced stops, like ds.palette(name, n); qualitative palettes pass through. */
	function sample(colors: string[], n: number, kind: string): string[] {
		if (kind === 'qualitative' || n >= colors.length) return colors;
		if (n === 1) return [colors[0]];
		return Array.from({ length: n }, (_, i) => colors[Math.round((i * (colors.length - 1)) / (n - 1))]);
	}

	async function renderOne(el: HTMLElement) {
		const name = el.dataset.preview;
		if (!name || !current.colors.length) return;
		const theme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
		const spec = structuredClone(await fetchSpec(name, theme));
		spec.config ??= {};
		spec.config.range ??= {};
		if (el.dataset.role === 'heatmap') {
			spec.config.range.heatmap = { scheme: current.colors };
			// Point/line marks draw continuous color from the ramp range (heatmap covers
			// only rect marks) - patch both so the scatter recolors too.
			spec.config.range.ramp = { scheme: current.colors };
		} else {
			const n = Number(el.dataset.n || '6');
			spec.config.range.category = sample(current.colors, n, current.kind);
		}
		views.get(el)?.finalize();
		el.innerHTML = '';
		views.set(el, await vegaEmbed(el, spec, { actions: false, renderer: 'svg', background: 'transparent' }));
		// Record the natural width and re-derive the shared zoom (see applyZoom).
		const svg = el.querySelector('svg');
		const natural = svg ? parseFloat(svg.getAttribute('width') ?? '0') : 0;
		if (natural > 0) {
			naturals.set(el, natural);
			applyZoom();
		}
	}

	// Auto-fit: zoom the charts to fill the column. With actions:false vega-embed makes the
	// container itself the .vega-embed with the <svg> directly inside - there is NO
	// .chart-wrapper child - so the site-wide wrapper zoom rule (theme.css) never applies here
	// and the chart paints at its natural ~180px unless the container is zoomed directly. The
	// zoom is SHARED (the minimum fit across the charts) so every chart renders at the same
	// scale - a per-chart fit made the narrower ones look blown up; the chart sources are
	// authored to near-equal natural widths so the shared fit still fills the column. The row
	// is measured, not the container (its own zoom would skew it), and a ResizeObserver
	// re-derives the zoom whenever the row's width settles - on first load the charts can
	// render before styles/layout do (a dev-server reload showed them small until the next
	// re-render), so sizing must react to layout, not assume it.
	function applyZoom() {
		const row = document.querySelector<HTMLElement>('.palprev__row');
		if (!row || !naturals.size) return;
		const rowWidth = row.getBoundingClientRect().width;
		if (rowWidth <= 0) return;
		const fits = [...naturals.values()].map((n) => rowWidth / n);
		const shared = Math.min(Math.max(Math.min(...fits), 1.2), 3.4).toFixed(3);
		for (const el of naturals.keys()) {
			(el.style as CSSStyleDeclaration & { zoom: string }).zoom = shared;
		}
	}

	function renderAll() {
		document.querySelectorAll<HTMLElement>('.palprev__chart[data-preview]').forEach((el) => renderOne(el));
	}

	function select(detail: { name: string; kind: string; colors: string[] }) {
		current = detail;
		const label = document.getElementById('palprev-name');
		if (label) label.textContent = detail.name;
		renderAll();
	}

	// The EXPLICIT copy actions (browsing clicks in the palette grid only select - they must
	// never take over the clipboard). Hex codes copy as a ready-to-paste list, what a scale
	// range wants; the name copies bare, what theme(palette=...) wants.
	function wireCopyButton(id: string, getText: () => string | null) {
		const btn = document.getElementById(id) as HTMLButtonElement | null;
		if (!btn || btn.dataset.wired) return;
		btn.dataset.wired = '1';
		btn.addEventListener('click', () => {
			const text = getText();
			if (!text) return;
			navigator.clipboard?.writeText(text);
			const prev = btn.textContent;
			btn.textContent = 'copied!';
			setTimeout(() => (btn.textContent = prev), 900);
		});
	}

	// Colorblindness simulator: apply the chosen feColorMatrix filter to the palette browser's
	// swatch grid AND the live preview charts (not the toolbar, so the controls stay true-color),
	// so a palette is judged as a CVD viewer would see it. Re-applies after page swaps.
	function applyCvd(value: string) {
		const filter = value ? `url(#cvd-${value})` : '';
		document.querySelectorAll<HTMLElement>('.pal__grid, .palprev__row').forEach((el) => {
			el.style.filter = filter;
		});
	}
	function wireCvd() {
		const sel = document.getElementById('palprev-cvd') as HTMLSelectElement | null;
		if (!sel || sel.dataset.wired) return;
		sel.dataset.wired = '1';
		sel.addEventListener('change', () => applyCvd(sel.value));
		applyCvd(sel.value); // re-assert on boot (a page swap keeps the selection)
	}

	// TEMPORARY site-theme toggle (light <-> dark): sets data-theme directly and never touches
	// Starlight's stored preference, so any navigation (full page load) restores the user's
	// real setting. Seeded from whatever theme is in effect on arrival. The existing
	// data-theme MutationObservers re-render every chart; the button shows Starlight's own
	// sun/moon iconography for the active mode.
	function wireThemeToggle() {
		const btn = document.getElementById('palprev-theme') as HTMLButtonElement | null;
		if (!btn || btn.dataset.wired) return;
		btn.dataset.wired = '1';
		let mode = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
		btn.dataset.mode = mode; // reflect the theme in effect; nothing applied yet
		btn.addEventListener('click', () => {
			mode = mode === 'light' ? 'dark' : 'light';
			btn.dataset.mode = mode;
			document.documentElement.dataset.theme = mode;
		});
	}

	function boot() {
		// A page swap replaces the chart elements: drop stale ones so they can't skew the
		// shared-minimum zoom, and re-fit whenever the (new) row's layout width changes.
		naturals.clear();
		const row = document.querySelector<HTMLElement>('.palprev__row');
		if (row) new ResizeObserver(() => applyZoom()).observe(row);
		// Seed from the FIRST swatch in the palette browser (baked data, no extra fetch) so the
		// default selection always follows whatever leads the generated palette list.
		if (!current.colors.length) {
			const seedEl = document.querySelector<HTMLElement>('.pal__item');
			if (seedEl) {
				current.name = seedEl.dataset.name ?? '';
				current.kind = seedEl.dataset.kind ?? 'sequential';
				current.colors = Array.from(seedEl.querySelectorAll<HTMLElement>('.pal__stop')).map(
					(s) => s.dataset.color ?? '',
				);
				seedEl.classList.add('is-selected');
				const label = document.getElementById('palprev-name');
				if (label) label.textContent = current.name;
			}
		}
		wireCopyButton('palprev-copy-name', () => current.name || null);
		wireCopyButton('palprev-copy', () =>
			current.colors.length ? `[${current.colors.map((c) => `"${c.toUpperCase()}"`).join(', ')}]` : null,
		);
		wireThemeToggle();
		wireCvd();
		renderAll();
	}

	document.addEventListener('ds-palette-select', ((ev: CustomEvent) => select(ev.detail)) as EventListener);
	boot();
	document.addEventListener('astro:page-load', boot);
	new MutationObserver(renderAll).observe(document.documentElement, {
		attributes: true,
		attributeFilter: ['data-theme'],
	});
</script>

<style>
	/* Mini-toolbar: copy/theme buttons in one row above the charts (visually beside the
	   browser's search bar in the two-column page layout); the "Previewing ..." status
	   sits on its own line below. */
	.palprev__bar {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.25rem;
		margin: 1rem 0 0.25rem; /* mirrors .pal__controls: row 1 of both columns */
	}
	.palprev__status {
		font-size: 0.85rem;
		color: var(--sl-color-gray-3);
		margin: 0.25rem 0 0.75rem; /* mirrors .pal__count: row 2 of both columns */
	}
	.palprev__theme svg {
		display: none;
		width: 0.9rem;
		height: 0.9rem;
	}
	.palprev__theme[data-mode='light'] svg[data-icon='light'],
	.palprev__theme[data-mode='dark'] svg[data-icon='dark'] {
		display: block;
	}
	/* Same size as the browser's kind-filter buttons (.pal__kinds button). */
	.palprev__btn {
		padding: 0.35rem 0.7rem;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		background: transparent;
		color: var(--sl-color-gray-3);
		font-size: 0.78rem;
		cursor: pointer;
		white-space: nowrap;
	}
	.palprev__btn:hover {
		color: var(--sl-color-text-accent);
		border-color: var(--sl-color-gray-4);
	}
	/* One column inside the palette page's sticky aside (~28rem); auto-fit lets the charts sit
	   side by side when the component gets full width (the narrow-screen stacked layout). */
	.palprev__row {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
		gap: 1rem;
		align-items: center;
		justify-items: start;
	}
	/* Each chart's zoom is set inline per render (auto-fit to the row width, see the script) -
	   the container IS the .vega-embed here (actions:false), so it is zoomed directly; the
	   site-wide .chart-wrapper rule never matches. */
	.palprev__chart {
		width: 100%;
		min-height: 6rem;
	}
</style>
