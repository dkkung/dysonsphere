---
// Live palette preview: three charts (categorical bars, multi-series lines, continuous heatmap)
// that re-render with whichever palette is selected in the <Palettes /> browser below - the same
// idea as the old gallery's "same charts over several palettes", but interactive.
//
// Mechanics: the base specs are the generated preview_* charts (authored against the default
// theme, no baked colors); on selection we patch the spec's `config.range` client-side - the
// bare `category` array for nominal scales (positional, like the library), `{scheme: [...]}`
// for the continuous heatmap - and re-embed. Sequential/diverging palettes are sampled to the
// series count exactly like `ds.palette(name, n)`; qualitative palettes pass through as-is.
// Listens for the `ds-palette-select` CustomEvent dispatched by Palettes.astro.
---

<div class="palprev not-content">
	<p class="palprev__status">
		Previewing <code id="palprev-name">ember</code> - click any palette in the browser below to
		restyle these charts.
	</p>
	<div class="palprev__row">
		<div class="palprev__chart" data-preview="preview_bars" data-role="category" data-n="6"></div>
		<div class="palprev__chart" data-preview="preview_lines" data-role="category" data-n="5"></div>
		<div class="palprev__chart" data-preview="preview_heatmap" data-role="heatmap"></div>
	</div>
</div>

<script>
	import vegaEmbed from 'vega-embed';

	const BASE = import.meta.env.BASE_URL;
	const specCache = new Map<string, Promise<any>>();
	const views = new WeakMap<HTMLElement, { finalize: () => void }>();

	let current: { name: string; kind: string; colors: string[] } = {
		name: 'ember',
		kind: 'sequential',
		colors: [], // resolved from the palette browser's data on first render
	};

	function fetchSpec(name: string, theme: string): Promise<any> {
		const key = `${name}-${theme}`;
		if (!specCache.has(key)) {
			specCache.set(
				key,
				fetch(`${BASE}charts/${key}.json`).then((r) => r.json()),
			);
		}
		return specCache.get(key)!;
	}

	/** n evenly spaced stops, like ds.palette(name, n); qualitative palettes pass through. */
	function sample(colors: string[], n: number, kind: string): string[] {
		if (kind === 'qualitative' || n >= colors.length) return colors;
		if (n === 1) return [colors[0]];
		return Array.from({ length: n }, (_, i) => colors[Math.round((i * (colors.length - 1)) / (n - 1))]);
	}

	async function renderOne(el: HTMLElement) {
		const name = el.dataset.preview;
		if (!name || !current.colors.length) return;
		const theme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
		const spec = structuredClone(await fetchSpec(name, theme));
		spec.config ??= {};
		spec.config.range ??= {};
		if (el.dataset.role === 'heatmap') {
			spec.config.range.heatmap = { scheme: current.colors };
		} else {
			const n = Number(el.dataset.n || '6');
			spec.config.range.category = sample(current.colors, n, current.kind);
		}
		views.get(el)?.finalize();
		el.innerHTML = '';
		views.set(el, await vegaEmbed(el, spec, { actions: false, renderer: 'svg', background: 'transparent' }));
	}

	function renderAll() {
		document.querySelectorAll<HTMLElement>('.palprev__chart[data-preview]').forEach((el) => renderOne(el));
	}

	function select(detail: { name: string; kind: string; colors: string[] }) {
		current = detail;
		const label = document.getElementById('palprev-name');
		if (label) label.textContent = detail.name;
		renderAll();
	}

	function boot() {
		// Seed from the palette browser's baked data so the default preview needs no extra fetch.
		const seedEl = document.querySelector<HTMLElement>(`.pal__item[data-name="${current.name}"]`);
		if (seedEl && !current.colors.length) {
			current.colors = Array.from(seedEl.querySelectorAll<HTMLElement>('.pal__stop')).map(
				(s) => s.style.background,
			);
		}
		renderAll();
	}

	document.addEventListener('ds-palette-select', ((ev: CustomEvent) => select(ev.detail)) as EventListener);
	boot();
	document.addEventListener('astro:page-load', boot);
	new MutationObserver(renderAll).observe(document.documentElement, {
		attributes: true,
		attributeFilter: ['data-theme'],
	});
</script>

<style>
	.palprev__status {
		font-size: 0.85rem;
		color: var(--sl-color-gray-3);
		margin: 1rem 0 0.25rem;
	}
	.palprev__row {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.75rem;
		align-items: center;
		justify-items: center;
	}
	@media (min-width: 60rem) {
		.palprev__row {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
	/* The site-wide chart zoom (theme.css) reads this variable off the embed's ancestors -
	   override it here rather than zooming the container (which would compound with it). */
	.palprev__chart {
		--ds-chart-zoom: 2;
		min-height: 8rem;
	}
	@media (max-width: 640px) {
		.palprev__chart {
			--ds-chart-zoom: 1.6;
		}
	}
</style>
