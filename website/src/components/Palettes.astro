---
// Live palette browser: renders every dysonsphere palette as a swatch strip, filterable by name
// and kind. Pure client-side (data baked from src/generated/palettes.json at build time) - no
// Pyodide. Click a swatch strip to SELECT it for the live preview; copying the hex codes is an
// explicit action (the copy button next to the preview status in PalettePreview.astro) so a
// browsing click never takes over the clipboard.
import palettes from '../generated/palettes.json';
---

{/* not-content: opt out of Starlight's sibling-margin content styling, which would push every
    grid item except the first down by a margin-top (the "first swatch rides high" bug). */}
<div class="pal not-content">
	<div class="pal__controls">
		<input id="pal-search" type="search" placeholder="Filter palettes…" aria-label="Filter palettes" />
		<div class="pal__kinds" role="group" aria-label="Palette kind">
			<button data-kind="all" class="is-active">All</button>
			<button data-kind="sequential">Sequential</button>
			<button data-kind="diverging">Diverging</button>
			<button data-kind="qualitative">Qualitative</button>
		</div>
	</div>
	<p id="pal-count" class="pal__count"></p>
	<div id="pal-grid" class="pal__grid">
		{
			palettes.map((p) => (
				<button class="pal__item" data-name={p.name} data-kind={p.kind} title={`Preview ${p.name}`}>
					<span class="pal__strip">
						{p.colors.map((c) => (
							<span class="pal__stop" data-color={c} style={`background:${c}`} />
						))}
					</span>
					<span class="pal__name">{p.name}</span>
				</button>
			))
		}
	</div>
</div>

<script>
	function initPalettes() {
		const grid = document.getElementById('pal-grid');
		if (!grid || grid.dataset.wired) return;
		grid.dataset.wired = '1';

		const search = document.getElementById('pal-search') as HTMLInputElement;
		const countEl = document.getElementById('pal-count') as HTMLElement;
		const kindBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.pal__kinds button'));
		const items = Array.from(grid.querySelectorAll<HTMLElement>('.pal__item'));
		let kind = 'all';

		const apply = () => {
			const q = search.value.trim().toLowerCase();
			let shown = 0;
			for (const el of items) {
				const okKind = kind === 'all' || el.dataset.kind === kind;
				const okName = !q || (el.dataset.name ?? '').includes(q);
				const show = okKind && okName;
				el.style.display = show ? '' : 'none';
				if (show) shown++;
			}
			countEl.textContent = `${shown} palette${shown === 1 ? '' : 's'}`;
		};

		search.addEventListener('input', apply);
		for (const btn of kindBtns) {
			btn.addEventListener('click', () => {
				kind = btn.dataset.kind ?? 'all';
				kindBtns.forEach((b) => b.classList.toggle('is-active', b === btn));
				apply();
			});
		}
		for (const el of items) {
			el.addEventListener('click', () => {
				const name = el.dataset.name ?? '';
				const colors = Array.from(el.querySelectorAll<HTMLElement>('.pal__stop')).map(
					(s) => s.dataset.color ?? '',
				);
				// Select for the live preview only - copying is the preview's explicit button
				// (PalettePreview.astro), never a side effect of browsing.
				items.forEach((i) => i.classList.toggle('is-selected', i === el));
				document.dispatchEvent(
					new CustomEvent('ds-palette-select', {
						detail: { name, kind: el.dataset.kind ?? 'sequential', colors },
					}),
				);
			});
		}
		apply();
	}

	initPalettes();
	document.addEventListener('astro:page-load', initPalettes);
</script>

<style>
	.pal__controls {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		align-items: center;
		margin: 1rem 0 0.25rem;
	}
	#pal-search {
		flex: 1 1 12rem;
		padding: 0.4rem 0.7rem;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		background: var(--sl-color-bg);
		color: var(--sl-color-text);
		font-size: 0.85rem;
	}
	.pal__kinds {
		display: flex;
		gap: 0.25rem;
	}
	.pal__kinds button {
		padding: 0.35rem 0.7rem;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		background: transparent;
		color: var(--sl-color-gray-3);
		font-size: 0.78rem;
		cursor: pointer;
	}
	.pal__kinds button.is-active {
		background: var(--sl-color-gray-6);
		color: var(--sl-color-white);
		border-color: var(--sl-color-gray-4);
	}
	.pal__count {
		font-size: 0.75rem;
		color: var(--sl-color-gray-3);
		margin: 0.25rem 0 0.75rem;
	}
	.pal__grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr));
		gap: 0.55rem 0.6rem;
	}
	/* Grouping: the name hugs its strip (small inner gap) while items sit clearly apart (grid
	   gap + chip padding), and hover paints one chip around strip + name - so there is no
	   ambiguity about which strip a name belongs to. */
	.pal__item {
		display: flex;
		flex-direction: column;
		gap: 0.14rem;
		margin: 0; /* belt-and-suspenders: grid rows must align even if content styling leaks in */
		padding: 0.32rem 0.4rem;
		border: 0;
		border-radius: 0.5rem;
		background: transparent;
		cursor: pointer;
		text-align: left;
		transition: background-color 0.12s ease;
	}
	.pal__item:hover,
	.pal__item.is-selected {
		background: var(--sl-color-gray-6);
	}
	.pal__strip {
		display: flex;
		height: 1.4rem;
		border-radius: 0.35rem;
		overflow: hidden;
		border: 1px solid var(--sl-color-hairline);
	}
	.pal__stop {
		flex: 1;
	}
	/* One line always: a wrapping long name would make its grid row taller and bump every row
	   below it. The full name is still in the title attribute (and copied on click). */
	.pal__name {
		font-family: var(--sl-font-mono);
		font-size: 0.72rem;
		color: var(--sl-color-gray-3);
		max-width: 100%;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.pal__item:hover .pal__name {
		color: var(--sl-color-text-accent);
	}
	.pal__item.is-selected .pal__strip {
		outline: 2px solid var(--sl-color-accent);
		outline-offset: 1px;
	}
	.pal__item.is-selected .pal__name {
		color: var(--sl-color-white);
	}
</style>
