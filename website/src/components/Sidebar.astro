---
// Starlight Sidebar override: the default sidebar content plus a desktop collapse toggle.
//
// The sidebar is rendered on EVERY page (the landing page uses the regular docs template), so
// docs are always one click away; this toggle lets readers reclaim the width. Collapsing sets
// `data-ds-sidebar="collapsed"` on <html> and zeroes `--sl-sidebar-width` (which Starlight's
// layout derives everything from - the content pane and header both reflow), persisted in
// localStorage. The toggle itself is position:fixed with `visibility: visible` so it survives
// the collapsed pane's `visibility: hidden` (visibility, unlike display, can be un-hidden by a
// descendant). Mobile keeps Starlight's hamburger; the toggle only shows on desktop.
import Default from '@astrojs/starlight/components/Sidebar.astro';
---

<Default><slot /></Default>

<button
	id="ds-sidebar-toggle"
	class="ds-sidebar-toggle"
	type="button"
	aria-controls="starlight__sidebar"
	aria-expanded="true"
	title="Collapse sidebar"
>
	<svg
		class="ds-sidebar-toggle__icon"
		width="16"
		height="16"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<rect x="3" y="4" width="18" height="16" rx="2"></rect>
		<line x1="9" y1="4" x2="9" y2="20"></line>
	</svg>
	<span class="sr-only">Toggle sidebar</span>
</button>

<script is:inline>
	// Apply the stored state as early as possible (and again after view-transition swaps, which
	// replace <html>'s attributes with the incoming page's).
	(() => {
		const KEY = 'ds-sidebar';
		const apply = () => {
			if (localStorage.getItem(KEY) === 'collapsed') {
				document.documentElement.dataset.dsSidebar = 'collapsed';
			} else {
				delete document.documentElement.dataset.dsSidebar;
			}
			const btn = document.getElementById('ds-sidebar-toggle');
			if (btn) {
				const collapsed = document.documentElement.dataset.dsSidebar === 'collapsed';
				btn.setAttribute('aria-expanded', String(!collapsed));
				btn.title = collapsed ? 'Expand sidebar' : 'Collapse sidebar';
			}
		};
		apply();
		if (!window._dsSidebarWired) {
			window._dsSidebarWired = true;
			document.addEventListener('astro:after-swap', apply);
			// Event delegation so the handler survives page swaps re-rendering the button.
			document.addEventListener('click', (ev) => {
				const btn = ev.target instanceof Element && ev.target.closest('#ds-sidebar-toggle');
				if (!btn) return;
				const collapsed = document.documentElement.dataset.dsSidebar === 'collapsed';
				if (collapsed) localStorage.removeItem(KEY);
				else localStorage.setItem(KEY, 'collapsed');
				apply();
			});
		}
	})();
</script>

<style>
	.ds-sidebar-toggle {
		display: none;
	}
	@media (min-width: 50rem) {
		.ds-sidebar-toggle {
			display: flex;
			align-items: center;
			justify-content: center;
			position: fixed;
			z-index: var(--sl-z-index-navbar);
			inset-block-end: 0.9rem;
			inset-inline-start: 0.9rem;
			width: 2rem;
			height: 2rem;
			padding: 0;
			border: 1px solid var(--sl-color-hairline);
			border-radius: 0.5rem;
			background: var(--sl-color-bg);
			color: var(--sl-color-gray-3);
			cursor: pointer;
			visibility: visible; /* survives the collapsed pane's visibility: hidden */
			transition:
				color 0.15s ease,
				border-color 0.15s ease;
		}
		.ds-sidebar-toggle:hover {
			color: var(--sl-color-white);
			border-color: var(--sl-color-gray-4);
		}
	}
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>
