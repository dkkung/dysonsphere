---
// Interactive dysonsphere playground: runs dysonsphere in the browser via the shared Pyodide
// runtime (src/lib/runtime.ts, also used by Chart Studio) and renders the result live with
// vega-embed. The editor is CodeMirror 6 with Python highlighting.
//
// Deep links: /playground/#code=<base64 utf-8> pre-fills the editor (used by every example's
// "Open in playground" link).
---

<div id="ds-playground" class="pg">
	<div class="pg__panel">
		<div class="pg__label">Python</div>
		<div id="pg-editor"></div>
		<div class="pg__toolbar">
			<button id="pg-run" disabled>Run</button>
			<span id="pg-status">Loading Python runtime…</span>
		</div>
		<p class="pg__hint">
			Assign your chart to a variable named <code>chart</code>. Use the actions menu on the chart to
			export SVG, PNG, or JSON.
		</p>
	</div>
	<div class="pg__panel">
		<div class="pg__label">Chart</div>
		<div id="pg-chart" class="pg__chart"></div>
	</div>
</div>

<script>
	import vegaEmbed from 'vega-embed';
	import { EditorView, basicSetup } from 'codemirror';
	import { python } from '@codemirror/lang-python';
	import { githubLight, githubDark } from '@uiw/codemirror-theme-github';
	import { Compartment } from '@codemirror/state';
	import { getRuntime, onRuntimeStatus, type DsRuntime } from '../lib/runtime';

	const DEFAULT_CODE = `import polars as pl
import altair as alt
import dysonsphere as ds

ds.theme(palette="blues")

df = pl.DataFrame({
    "group": ["A", "B", "C", "D"],
    "value": [3.0, 5.0, 2.0, 6.0],
})

chart = (
    alt.Chart(df)
    .mark_bar()
    .encode(
        x=alt.X("group:N"),
        y=alt.Y("value:Q"),
        color=alt.Color("group:N", legend=None),
    )
)
`;

	const isDark = () => document.documentElement.dataset.theme === 'dark';

	/** Code from a #code=<base64> deep link, if present and decodable. */
	function hashCode(): string | null {
		const m = location.hash.match(/#code=([^&]+)/);
		if (!m) return null;
		try {
			const bytes = Uint8Array.from(atob(decodeURIComponent(m[1])), (c) => c.charCodeAt(0));
			return new TextDecoder().decode(bytes);
		} catch {
			return null;
		}
	}

	async function initPlayground() {
		const root = document.getElementById('ds-playground');
		if (!root || root.dataset.booted) return;
		root.dataset.booted = '1';

		const statusEl = document.getElementById('pg-status') as HTMLElement;
		const runBtn = document.getElementById('pg-run') as HTMLButtonElement;
		const chartEl = document.getElementById('pg-chart') as HTMLElement;
		const editorParent = document.getElementById('pg-editor') as HTMLElement;

		// CodeMirror editor with Python highlighting; theme follows the site's light/dark toggle.
		// GitHub theme to match the docs code blocks; swaps light/dark with the site toggle.
		const themeCompartment = new Compartment();
		const cmTheme = () => (isDark() ? githubDark : githubLight);
		const editor = new EditorView({
			doc: hashCode() ?? DEFAULT_CODE,
			extensions: [basicSetup, python(), themeCompartment.of(cmTheme())],
			parent: editorParent,
		});
		new MutationObserver(() => {
			editor.dispatch({ effects: themeCompartment.reconfigure(cmTheme()) });
			if (runtime) run(); // re-render the chart in the new theme's ink
		}).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

		// A new #code= deep link while already on this page (e.g. a second "Open in playground"
		// click) should replace the editor contents and re-run.
		window.addEventListener('hashchange', () => {
			const code = hashCode();
			if (code === null) return;
			editor.dispatch({ changes: { from: 0, to: editor.state.doc.length, insert: code } });
			if (runtime) run();
		});

		const setStatus = (msg: string, kind = '') => {
			statusEl.textContent = msg;
			statusEl.dataset.kind = kind;
		};

		let runtime: DsRuntime | null = null;

		async function run() {
			if (!runtime) return;
			setStatus('Running…');
			runBtn.disabled = true;
			try {
				const spec = JSON.parse(runtime.runChart(editor.state.doc.toString(), isDark()));
				await vegaEmbed(chartEl, spec, { actions: true, renderer: 'svg', background: 'transparent' });
				setStatus('Rendered.', 'ok');
			} catch (e) {
				setStatus('Error - see console.', 'err');
				console.error(e);
			} finally {
				runBtn.disabled = false;
			}
		}

		try {
			onRuntimeStatus((msg) => {
				// Boot progress; once running, run()/setStatus takes over.
				if (!runtime) setStatus(msg);
			});
			runtime = await getRuntime();
			runBtn.disabled = false;
			runBtn.addEventListener('click', run);
			await run();
		} catch (e) {
			setStatus('Boot failed - see console.', 'err');
			console.error(e);
		}
	}

	initPlayground();
	// Starlight navigates with view transitions; boot when arriving on the playground page.
	document.addEventListener('astro:page-load', initPlayground);
</script>

<style>
	.pg {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		align-items: start;
		margin-top: 1.5rem;
	}
	@media (max-width: 800px) {
		.pg {
			grid-template-columns: 1fr;
		}
	}
	.pg__panel {
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.65rem;
		overflow: hidden;
		background: var(--sl-color-bg);
	}
	.pg__label {
		padding: 0.5rem 0.75rem;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
		border-bottom: 1px solid var(--sl-color-gray-5);
	}
	/* CodeMirror renders its own DOM, so size it with global selectors. */
	:global(#pg-editor .cm-editor) {
		height: 22rem;
		font-size: 0.8rem;
	}
	:global(#pg-editor .cm-scroller) {
		overflow: auto;
	}
	.pg__toolbar {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.6rem 0.75rem;
		border-top: 1px solid var(--sl-color-gray-5);
	}
	#pg-run {
		background: var(--sl-color-white);
		color: var(--sl-color-black);
		border: 0;
		border-radius: 0.45rem;
		padding: 0.4rem 1rem;
		font-weight: 550;
		cursor: pointer;
		transition: opacity 0.15s ease;
	}
	#pg-run:hover:not(:disabled) {
		opacity: 0.85;
	}
	#pg-run:disabled {
		opacity: 0.55;
		cursor: default;
	}
	#pg-status {
		font-size: 0.8rem;
		color: var(--sl-color-gray-3);
	}
	#pg-status[data-kind='ok'] {
		color: var(--sl-color-green, #2f7d4f);
	}
	#pg-status[data-kind='err'] {
		color: var(--sl-color-red, #b23b3b);
	}
	.pg__hint {
		margin: 0;
		padding: 0 0.75rem 0.75rem;
		font-size: 0.75rem;
		color: var(--sl-color-gray-3);
	}
	.pg__chart {
		padding: 1rem;
		min-height: 22rem;
		overflow: auto;
	}
</style>
