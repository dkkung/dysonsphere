---
// One registry example: the VERBATIM source of website/examples/<name>.py as the code block,
// the live chart rendered from its generated specs, and an "Open in studio" deep link (the
// Chart Studio's code editor). Because the shown code IS the file the generator executed,
// snippet and chart cannot drift.
import { Code } from '@astrojs/starlight/components';
import Chart from './Chart.astro';

interface Props {
	name: string;
	alt?: string;
	/** Hide the code block (chart only) - for gallery-style pages. */
	chartOnly?: boolean;
	/** Chart with a toggle button that swaps the source INTO the chart's footprint (code
	    hidden by default). For the gallery: a clean figure that reveals its code on demand. */
	codeToggle?: boolean;
	/** Short note under the chart (what it is / the calls that made it) - for gallery pages. */
	caption?: string;
	/** Apply the save()-time inward-ticks SVG fix (theme(inwardTicks=True) charts). */
	inwardTicks?: boolean;
}
const { name, alt, chartOnly = false, codeToggle = false, caption, inwardTicks = false } = Astro.props;

const sources = import.meta.glob('../../examples/*.py', {
	query: '?raw',
	import: 'default',
	eager: true,
}) as Record<string, string>;

const source = sources[`../../examples/${name}.py`];
if (!source) throw new Error(`No example source: website/examples/${name}.py`);
const code = source.trimEnd();

// Deep link: /studio/#code=<base64 utf-8>. Decoded by the studio's code editor on load.
const studioHref = `${import.meta.env.BASE_URL}studio/#code=${encodeURIComponent(
	Buffer.from(code, 'utf-8').toString('base64'),
)}`;
const chartAlt = alt ?? `dysonsphere example: ${name}`;
---

{
	codeToggle ? (
		<figure class="example example--toggle" data-code-toggle>
			<button class="example__codebtn" data-role="toggle" type="button" aria-pressed="false">
				<span data-when="chart">&lt;/&gt; code</span>
				<span data-when="code" hidden>← chart</span>
			</button>
			<div class="example__pane" data-pane="chart">
				<div class="example__row">
					<Chart name={name} alt={chartAlt} inwardTicks={inwardTicks} />
				</div>
			</div>
			<div class="example__pane" data-pane="code" hidden>
				<Code lang="python" code={code} />
			</div>
			{caption && <figcaption class="example__caption" set:html={caption} />}
			<div class="example__actions">
				<a href={studioHref}>Open in studio &rarr;</a>
			</div>
		</figure>
	) : (
		<div class="example">
			{!chartOnly && <Code lang="python" code={code} />}
			<div class="example__row">
				<Chart name={name} alt={chartAlt} inwardTicks={inwardTicks} />
			</div>
			{caption && <p class="example__caption" set:html={caption} />}
			<div class="example__actions">
				<a href={studioHref}>Open in studio &rarr;</a>
			</div>
		</div>
	)
}

<script>
	function wireToggles() {
		document.querySelectorAll<HTMLElement>('[data-code-toggle]').forEach((el) => {
			if (el.dataset.wired) return;
			el.dataset.wired = '1';
			const btn = el.querySelector<HTMLButtonElement>('[data-role="toggle"]');
			const chartPane = el.querySelector<HTMLElement>('[data-pane="chart"]');
			const codePane = el.querySelector<HTMLElement>('[data-pane="code"]');
			if (!btn || !chartPane || !codePane) return;
			btn.addEventListener('click', () => {
				const showCode = codePane.hidden;
				codePane.hidden = !showCode;
				chartPane.hidden = showCode;
				btn.setAttribute('aria-pressed', String(showCode));
				btn.querySelector<HTMLElement>('[data-when="chart"]')!.hidden = showCode;
				btn.querySelector<HTMLElement>('[data-when="code"]')!.hidden = !showCode;
			});
		});
	}
	wireToggles();
	document.addEventListener('astro:page-load', wireToggles);
</script>

<style>
	.example {
		margin: 1.5rem 0 2.5rem;
	}
	/* The chart sits flush with the code cell above it: left-aligned to the same content edge
	   and with a tightened vertical gap, so code and figure read as one unit. */
	.example__row {
		display: flex;
		justify-content: flex-start;
	}
	.example__row :global(.ds-chart) {
		margin: 0.6rem 0 0;
	}
	.example__row :global(.ds-chart__view) {
		justify-content: flex-start;
		padding: 0;
	}
	.example__caption {
		margin: 0.35rem 0 0;
		font-size: 0.8rem;
		color: var(--sl-color-gray-3);
	}
	.example__caption :global(code) {
		font-family: var(--sl-font-mono);
		font-size: 0.72rem;
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 0.3rem;
		padding: 0.05em 0.3em;
	}
	/* Revealed only while the example is hovered or focused, like the chart's export menu. */
	.example__actions {
		display: flex;
		justify-content: flex-end;
		opacity: 0;
		transition: opacity 0.15s ease;
	}
	.example:hover .example__actions,
	.example:focus-within .example__actions {
		opacity: 1;
	}
	.example__actions a {
		font-size: 0.8rem;
		color: var(--sl-color-gray-3);
		text-decoration: none;
	}
	.example__actions a:hover {
		color: var(--sl-color-text-accent);
	}

	/* --- Code-toggle (gallery) variant --- */
	.example--toggle {
		position: relative;
		margin: 0;
	}
	/* A subtle always-visible affordance in the figure's top-right; brightens on hover so it
	   reads as interactive without competing with the chart. */
	.example__codebtn {
		position: absolute;
		top: 0.1rem;
		right: 0.1rem;
		z-index: 2;
		padding: 0.1rem 0.45rem;
		border: 1px solid var(--sl-color-hairline);
		border-radius: 0.4rem;
		background: var(--sl-color-bg);
		color: var(--sl-color-gray-3);
		font-family: var(--sl-font-mono);
		font-size: 0.68rem;
		line-height: 1.5;
		cursor: pointer;
		opacity: 0.55;
		transition: opacity 0.12s ease, color 0.12s ease;
	}
	.example--toggle:hover .example__codebtn,
	.example__codebtn:focus-visible {
		opacity: 1;
		color: var(--sl-color-text-accent);
	}
	/* The code pane fills the chart's footprint when revealed; its own scroll if long. */
	.example__pane[data-pane='code'] :global(.expressive-code) {
		margin: 0.2rem 0 0;
	}
</style>
