---
// One registry example: the VERBATIM source of website/examples/<name>.py as the code block,
// the live chart rendered from its generated specs, and an "Open in studio" deep link (the
// Chart Studio's code editor). Because the shown code IS the file the generator executed,
// snippet and chart cannot drift.
import { Code } from '@astrojs/starlight/components';
import Chart from './Chart.astro';

interface Props {
	name: string;
	alt?: string;
	/** Hide the code block (chart only) - for gallery-style pages. */
	chartOnly?: boolean;
}
const { name, alt, chartOnly = false } = Astro.props;

const sources = import.meta.glob('../../examples/*.py', {
	query: '?raw',
	import: 'default',
	eager: true,
}) as Record<string, string>;

const source = sources[`../../examples/${name}.py`];
if (!source) throw new Error(`No example source: website/examples/${name}.py`);
const code = source.trimEnd();

// Deep link: /studio/#code=<base64 utf-8>. Decoded by the studio's code editor on load.
const studioHref = `${import.meta.env.BASE_URL}studio/#code=${encodeURIComponent(
	Buffer.from(code, 'utf-8').toString('base64'),
)}`;
---

<div class="example">
	{!chartOnly && <Code lang="python" code={code} />}
	<div class="example__row">
		<Chart name={name} alt={alt ?? `dysonsphere example: ${name}`} />
	</div>
	<div class="example__actions">
		<a href={studioHref}>Open in studio &rarr;</a>
	</div>
</div>

<style>
	.example {
		margin: 1.5rem 0 2.5rem;
	}
	/* The chart sits flush with the code cell above it: left-aligned to the same content edge
	   and with a tightened vertical gap, so code and figure read as one unit. */
	.example__row {
		display: flex;
		justify-content: flex-start;
	}
	.example__row :global(.ds-chart) {
		margin: 0.6rem 0 0;
	}
	.example__row :global(.ds-chart__view) {
		justify-content: flex-start;
		padding: 0;
	}
	.example__actions {
		display: flex;
		justify-content: flex-end;
	}
	.example__actions a {
		font-size: 0.8rem;
		color: var(--sl-color-gray-3);
		text-decoration: none;
	}
	.example__actions a:hover {
		color: var(--sl-color-text-accent);
	}
</style>
