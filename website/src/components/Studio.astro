	/* vega-embed tags the chart div itself with .vega-embed { display: inline-block } at
	   runtime; the scoped rule above compiles to a zero-specificity :where() and loses the
	   tie, letting the div shrink-wrap its ZOOMED content and overflow the panel. An id
	   selector outranks it. */
	:global(#st-chart) {
		display: flex !important;
		width: 100%;
		max-width: 100%;
	}
	.st__error {
		margin: 0;
		padding: 0.75rem 1rem;
		border-top: 1px solid var(--sl-color-gray-5);
