---
// Chart Studio: an interactive plotter AND a live Python editor over the shared Pyodide runtime.
//
// Two modes share one chart panel:
//   - Build: upload a CSV/TSV/JSON (or use the bundled sample), pick encodings and a chart type,
//     layer on statistics, a multilabel table, and annotations, tune the theme - and read the
//     exact Python that reproduces the chart.
//   - Code: a CodeMirror editor (the absorbed playground). "Edit as code" seeds it from the
//     builder's current snippet; #code= deep links land here directly.
//
// "Import an export" takes a file saved by ds.save(): a Vega-Lite JSON rebuilds the chart via
// ds.load() (seeded + run in the code editor, so the shown snippet is what executed); JSON,
// SVG, and PNG all read their embedded dysonsphere block back via ds.read() into a metadata
// panel (report + structured JSON).
//
// Uploaded data is written into the runtime's virtual filesystem under its real filename, so the
// emitted `pl.read_csv("file.csv")` line runs verbatim - the shown code IS the executed code.
import palettes from '../generated/palettes.json';

const paletteGroups = [
	{ label: 'Sequential', kind: 'sequential' },
	{ label: 'Diverging', kind: 'diverging' },
	{ label: 'Qualitative', kind: 'qualitative' },
].map((g) => ({ ...g, names: palettes.filter((p) => p.kind === g.kind).map((p) => p.name) }));
---

<div id="studio" class="st not-content">
	<div class="st__controls">
		<section class="st__group">
			<h3>Data</h3>
			<label class="st__file">
				<input id="st-file" type="file" accept=".csv,.tsv,.json,.txt" />
			</label>
			<label>Or a sample dataset
				<select id="st-dataset">
					<option value="cars">cars</option>
					<option value="sample">dose-response (synthetic)</option>
					<option value="iris">iris</option>
					<option value="barley">barley</option>
					<option value="stocks">stocks</option>
					<option value="seattle_weather">seattle_weather</option>
				</select>
			</label>
			<p id="st-data-info" class="st__muted"></p>
		</section>

		<section class="st__group">
			<h3>Import an export</h3>
			<label class="st__file">
				<input id="st-export-file" type="file" accept=".json,.svg,.png" />
			</label>
			<p class="st__muted">
				Drop a file saved by <code>ds.save()</code>: a JSON rebuilds the chart
				via <code>ds.load()</code>; JSON, SVG, and PNG all read their embedded metadata back
				(shown below the chart).
			</p>
		</section>

		<section class="st__group">
			<h3>Chart</h3>
			<label>Type
				<select id="st-type">
					<option value="point">Scatter</option>
					<option value="strip">Strip</option>
					<option value="violin">Violin</option>
					<option value="boxplot">Boxplot</option>
					<option value="bar">Bar</option>
					<option value="line">Line</option>
				</select>
			</label>
			<label>X <select id="st-x"></select></label>
			<label class="st__inline" id="st-xtype-wrap">X type
				<select id="st-xtype">
					<option value="N">Nominal</option>
					<option value="Q">Quantitative</option>
					<option value="T">Temporal</option>
				</select>
			</label>
			<label>Y <select id="st-y"></select></label>
			<label id="st-color-wrap">Color <select id="st-color"><option value="">(none)</option></select></label>
			<label id="st-transform-wrap">Point spread
				<select id="st-transform">
					<option value="">None</option>
					<option value="jitter">Jitter</option>
					<option value="beeswarm">Beeswarm</option>
				</select>
			</label>
			<div id="st-strip-opts">
				<label>Scatter
					<select id="st-scatter">
						<option value="jitter">Jitter</option>
						<option value="beeswarm">Beeswarm</option>
					</select>
				</label>
				<label class="st__check"><input id="st-errorbars" type="checkbox" checked /> Mean error bars</label>
				<label id="st-extent-wrap">Error bar extent
					<select id="st-extent">
						<option value="sem">Standard error</option>
						<option value="sd">Standard deviation</option>
					</select>
				</label>
			</div>
		</section>

		<section class="st__group" id="st-stats-group">
			<h3>Statistics</h3>
			<div id="st-comparisons-wrap">
				<label>Test
					<select id="st-test">
						<option value="">None</option>
						<option value="mannwhitneyu">Mann-Whitney U (pairwise)</option>
						<option value="ttest_ind">t-test (pairwise)</option>
						<option value="kruskal">Kruskal-Wallis + Dunn</option>
						<option value="anova">ANOVA + Tukey HSD</option>
					</select>
				</label>
				<label id="st-brackets-wrap">Brackets
					<select id="st-brackets">
						<option value="none">Omnibus label only</option>
						<option value="all">All pairs (post-hoc)</option>
					</select>
				</label>
				<label id="st-labelstyle-wrap">Label style
					<select id="st-labelstyle">
						<option value="p">P values</option>
						<option value="asterisks">Asterisks</option>
					</select>
				</label>
			</div>
			<div id="st-correlation-wrap">
				<label>Correlation
					<select id="st-correlation">
						<option value="">None</option>
						<option value="pearson">Pearson (r + fit line)</option>
						<option value="spearman">Spearman (&rho;)</option>
						<option value="kendall">Kendall (&tau;)</option>
					</select>
				</label>
				<label class="st__check" id="st-corr-verbose-wrap">
					<input id="st-corr-verbose" type="checkbox" /> Verbose readout
				</label>
			</div>
		</section>

		<section class="st__group" id="st-table-group">
			<h3>Multilabel</h3>
			<label class="st__check"><input id="st-multilabel" type="checkbox" /> Attach multilabel table</label>
			<div id="st-multilabel-opts">
				<label>Rows - one per line, <code>Label: +,-,+</code>
					<textarea id="st-rows" rows="3" spellcheck="false" placeholder="Treated: -,+,+&#10;Fasted: -,-,+"></textarea>
				</label>
				<label class="st__check"><input id="st-samplesize" type="checkbox" checked /> Sample size row (n =)</label>
				<label class="st__check"><input id="st-catlabels" type="checkbox" checked /> Category labels</label>
			</div>
		</section>

		<section class="st__group" id="st-annot-group">
			<h3>Annotations</h3>
			<label>Reference line (y) <input id="st-rule" type="number" step="any" placeholder="(none)" /></label>
			<label id="st-rule-label-wrap">Line label <input id="st-rule-label" type="text" placeholder="(none)" /></label>
			<label>Text annotation <input id="st-text" type="text" placeholder="(none)" /></label>
			<label id="st-text-pos-wrap">Text position
				<select id="st-text-pos">
					<option value="topLeft">Top left</option>
					<option value="topCenter">Top center</option>
					<option value="topRight">Top right</option>
					<option value="middleLeft">Middle left</option>
					<option value="middleCenter">Middle center</option>
					<option value="middleRight">Middle right</option>
					<option value="bottomLeft">Bottom left</option>
					<option value="bottomCenter">Bottom center</option>
					<option value="bottomRight">Bottom right</option>
				</select>
			</label>
			<div class="st__dims">
				<label>Shade y from <input id="st-shade-lo" type="number" step="any" placeholder="(none)" /></label>
				<label>to <input id="st-shade-hi" type="number" step="any" placeholder="(none)" /></label>
			</div>
			<label class="st__check" id="st-shade-wrap"><input id="st-shade" type="checkbox" /> Shade alternating bands</label>
		</section>

		<section class="st__group">
			<h3>Theme</h3>
			<label>Palette
				<select id="st-palette">
					<option value="">(default)</option>
					{paletteGroups.map((g) => (
						<optgroup label={g.label}>
							{g.names.map((n) => (
								<option value={n}>{n}</option>
							))}
						</optgroup>
					))}
				</select>
				<span id="st-palette-preview" class="st__swatch" aria-hidden="true"></span>
			</label>
			<div class="st__dims">
				<label>Width <input id="st-w" type="number" min="40" max="600" step="10" value="100" /></label>
				<label>Height <input id="st-h" type="number" min="40" max="600" step="10" value="100" /></label>
			</div>
			<label>Axis offset <input id="st-axisoffset" type="number" min="0" max="20" step="0.5" placeholder="auto" /></label>
			<label>X label angle <input id="st-xangle" type="number" min="-90" max="90" step="15" value="0" /></label>
			<div class="st__toggles">
				<label class="st__check"><input id="st-legend" type="checkbox" checked /> Legend</label>
				<label class="st__check"><input id="st-closed" type="checkbox" /> Closed frame</label>
				<label class="st__check"><input id="st-grid" type="checkbox" /> Grid lines</label>
				<label class="st__check"><input id="st-corner" type="checkbox" /> Rounded marks</label>
			</div>
		</section>
	</div>

	<div class="st__output">
		<div class="st__panel">
			<div class="st__label">
				Chart <span id="st-status" class="st__status">Loading runtime…</span>
			</div>
			<div id="st-chart" class="st__chart"></div>
			<pre id="st-error" class="st__error" hidden></pre>
		</div>
		<div class="st__panel" id="st-meta-panel" hidden>
			<div class="st__label">
				<span id="st-meta-title">Export metadata</span>
				<button id="st-meta-close" class="st__copy" type="button">Hide</button>
			</div>
			<div class="st__meta">
				<h4>Report</h4>
				<pre id="st-meta-report"></pre>
				<h4>Structured block (<code>ds.read(path, what="metadata")</code>)</h4>
				<pre id="st-meta-json"></pre>
			</div>
		</div>
		<div class="st__panel">
			<div class="st__label">
				<span id="st-code-title">Python</span>
				<span class="st__label-actions">
					<button id="st-run" class="st__copy st__run" type="button" hidden>Run &#9654;</button>
					<button id="st-edit" class="st__copy" type="button">Edit as code</button>
					<button id="st-back" class="st__copy" type="button" hidden>Back to builder</button>
					<button id="st-copy" class="st__copy" type="button">Copy</button>
				</span>
			</div>
			<div id="st-code-view"></div>
			<div id="st-editor" hidden></div>
			<p class="st__hint" id="st-editor-hint" hidden>
				Define a variable named <code>chart</code>. Run with the button or
				<kbd>Cmd/Ctrl</kbd>+<kbd>Enter</kbd>. Your uploaded file is available under its own
				filename (e.g. <code>pl.read_csv("data.csv")</code>).
			</p>
		</div>
	</div>
</div>

<script>
	import vegaEmbed from 'vega-embed';
	import { alignGridToContent, fixSuperscripts, italicizeStatSymbols } from '../lib/fixSuperscripts';
	import { EditorView, basicSetup } from 'codemirror';
	import { keymap } from '@codemirror/view';
	import { python } from '@codemirror/lang-python';
	import { githubLight, githubDark } from '@uiw/codemirror-theme-github';
	import { Compartment, EditorState } from '@codemirror/state';
	import { getRuntime, onRuntimeStatus, type DsRuntime } from '../lib/runtime';
	import palettes from '../generated/palettes.json';

	const PALETTE_COLORS: Record<string, string[]> = Object.fromEntries(
		palettes.map((p) => [p.name, p.colors]),
	);

	// A small self-contained sample: made-up dose/response with a categorical treatment.
	const SAMPLE = `treatment,dose,response,replicate
control,0,4.1,1
control,0,3.6,2
control,0,4.4,3
control,0,3.9,4
control,0,4.6,5
control,0,3.4,6
low,10,11.2,1
low,10,9.8,2
low,10,12.5,3
low,10,10.9,4
low,10,11.9,5
low,10,10.1,6
high,100,24.6,1
high,100,27.1,2
high,100,22.9,3
high,100,25.8,4
high,100,23.9,5
high,100,26.4,6`;

	interface Column {
		name: string;
		dtype: string;
		kind: 'quantitative' | 'temporal' | 'nominal';
		nUnique: number;
	}

	const isDark = () => document.documentElement.dataset.theme === 'dark';
	const q = (s: string) => `"${s.replace(/"/g, '\\"')}"`;
	const el = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;

	/** Code from a #code=<base64 utf-8> deep link, if present and decodable. */
	function hashCode(): string | null {
		const m = location.hash.match(/#code=([^&]+)/);
		if (!m) return null;
		try {
			const bytes = Uint8Array.from(atob(decodeURIComponent(m[1])), (c) => c.charCodeAt(0));
			return new TextDecoder().decode(bytes);
		} catch {
			return null;
		}
	}

	function initStudio() {
		const root = document.getElementById('studio');
		if (!root || root.dataset.booted) return;
		root.dataset.booted = '1';

		const statusEl = el('st-status');
		const chartEl = el('st-chart');
		const errorEl = el('st-error');
		const dataInfo = el('st-data-info');

		let runtime: DsRuntime | null = null;
		let columns: Column[] = [];
		let fileName = 'data.csv';
		let fileFormat: 'csv' | 'tsv' | 'json' = 'csv';
		let mode: 'build' | 'code' = hashCode() === null ? 'build' : 'code';

		const setStatus = (msg: string, kind = '') => {
			statusEl.textContent = msg;
			statusEl.dataset.kind = kind;
		};
		const showError = (e: unknown) => {
			// Show the tail of a Python traceback (the informative part) inline.
			const text = String((e as Error)?.message ?? e);
			const lines = text.trimEnd().split('\n');
			errorEl.textContent = lines.slice(-14).join('\n');
			errorEl.hidden = false;
		};
		const clearError = () => {
			errorEl.hidden = true;
		};

		// ------------------------------------------------------------------ editor (code mode)

		const themeCompartment = new Compartment();
		const cmTheme = () => (isDark() ? githubDark : githubLight);
		const editor = new EditorView({
			doc: hashCode() ?? '',
			extensions: [
				basicSetup,
				python(),
				themeCompartment.of(cmTheme()),
				keymap.of([
					{
						key: 'Mod-Enter',
						run: () => {
							runCode();
							return true;
						},
					},
				]),
			],
			parent: el('st-editor'),
		});
		// The builder's generated snippet gets the same Python highlighting, in a read-only
		// CodeMirror (no cursor, not editable - it is a view, "Edit as code" is the way in).
		const builderThemeCompartment = new Compartment();
		const builderView = new EditorView({
			doc: '',
			extensions: [
				basicSetup,
				python(),
				builderThemeCompartment.of(cmTheme()),
				EditorView.editable.of(false),
				EditorState.readOnly.of(true),
			],
			parent: el('st-code-view'),
		});
		const setBuilderCode = (code: string) => {
			builderView.dispatch({ changes: { from: 0, to: builderView.state.doc.length, insert: code } });
		};
		// Web fonts load after CodeMirror measures its text: without a re-measure the cursor
		// lands visibly off from the click position (the reported playground bug). Re-measure
		// once the fonts settle.
		document.fonts?.ready.then(() => {
			editor.requestMeasure();
			builderView.requestMeasure();
		});

		function setMode(next: 'build' | 'code', seed?: string) {
			mode = next;
			const isCode = next === 'code';
			el('st-code-view').hidden = isCode;
			el('st-editor').hidden = !isCode;
			el('st-editor-hint').hidden = !isCode;
			el<HTMLButtonElement>('st-run').hidden = !isCode;
			el<HTMLButtonElement>('st-edit').hidden = isCode;
			el<HTMLButtonElement>('st-back').hidden = !isCode;
			el('st-code-title').textContent = isCode ? 'Python (editable)' : 'Python';
			if (seed !== undefined) {
				editor.dispatch({ changes: { from: 0, to: editor.state.doc.length, insert: seed } });
			}
			if (isCode) {
				editor.requestMeasure();
				editor.focus();
			}
		}

		// ------------------------------------------------------------------ builder helpers

		function fillSelect(id: string, includeNone = false, onlyKind?: Column['kind']) {
			const sel = el<HTMLSelectElement>(id);
			const prev = sel.value;
			// Filter to a kind when asked, but fall back to all columns if none match (e.g. a
			// dataset with no numeric column would otherwise leave Y empty).
			let cols = onlyKind ? columns.filter((c) => c.kind === onlyKind) : columns;
			if (!cols.length) cols = columns;
			sel.innerHTML = includeNone ? '<option value="">(none)</option>' : '';
			for (const c of cols) {
				const opt = document.createElement('option');
				opt.value = c.name;
				opt.textContent = `${c.name}  ·  ${c.kind[0].toUpperCase()}`;
				sel.appendChild(opt);
			}
			if (prev && cols.some((c) => c.name === prev)) sel.value = prev;
		}

		// Pick sensible defaults after a new table loads. Y prefers the quantitative column with
		// the most distinct values - the measured variable, not a dose level or replicate id.
		function seedEncodings() {
			const cat = columns.find((c) => c.kind === 'nominal');
			const quant = [...columns.filter((c) => c.kind === 'quantitative')].sort(
				(a, b) => b.nUnique - a.nUnique,
			);
			const temporal = columns.find((c) => c.kind === 'temporal');
			el<HTMLSelectElement>('st-x').value = (cat ?? temporal ?? quant[0] ?? columns[0]).name;
			el<HTMLSelectElement>('st-y').value = (quant[0] ?? columns[columns.length - 1]).name;
			el<HTMLSelectElement>('st-color').value = '';
			syncXType();
		}

		function syncXType() {
			const xName = el<HTMLSelectElement>('st-x').value;
			const col = columns.find((c) => c.name === xName);
			if (!col) return;
			const map = { nominal: 'N', quantitative: 'Q', temporal: 'T' } as const;
			el<HTMLSelectElement>('st-xtype').value = map[col.kind];
		}

		function isCategorical(): boolean {
			const type = el<HTMLSelectElement>('st-type').value;
			const xtype = el<HTMLSelectElement>('st-xtype').value;
			return (
				type === 'strip' ||
				type === 'violin' ||
				type === 'boxplot' ||
				((type === 'bar' || type === 'point') && xtype === 'N')
			);
		}

		// Which controls are relevant for the current chart type / encodings.
		function syncVisibility() {
			const type = el<HTMLSelectElement>('st-type').value;
			const xtype = el<HTMLSelectElement>('st-xtype').value;
			const categorical = isCategorical();
			const groupComparisons = type === 'strip' || type === 'violin' || type === 'boxplot';
			const scatterQ = type === 'point' && xtype === 'Q';

			el('st-xtype-wrap').style.display =
				type === 'strip' || type === 'violin' || type === 'boxplot' ? 'none' : '';
			el('st-transform-wrap').style.display = type === 'point' && xtype === 'N' ? '' : 'none';
			el('st-strip-opts').style.display = type === 'strip' ? '' : 'none';
			el('st-extent-wrap').style.display =
				type === 'strip' && el<HTMLInputElement>('st-errorbars').checked ? '' : 'none';
			// mark_strip/mark_violin color by category internally; the color channel applies to
			// the plain Altair marks only.
			el('st-color-wrap').style.display =
				type === 'strip' || type === 'violin' || type === 'boxplot' ? 'none' : '';

			el('st-comparisons-wrap').style.display = groupComparisons ? '' : 'none';
			el('st-correlation-wrap').style.display = scatterQ ? '' : 'none';
			el('st-stats-group').style.display = groupComparisons || scatterQ ? '' : 'none';
			const test = el<HTMLSelectElement>('st-test').value;
			const omnibus = test === 'kruskal' || test === 'anova';
			el('st-brackets-wrap').style.display = groupComparisons && omnibus ? '' : 'none';
			el('st-labelstyle-wrap').style.display = groupComparisons && test ? '' : 'none';
			el('st-corr-verbose-wrap').style.display =
				scatterQ && el<HTMLSelectElement>('st-correlation').value ? '' : 'none';

			el('st-table-group').style.display = categorical ? '' : 'none';
			el('st-multilabel-opts').style.display =
				categorical && el<HTMLInputElement>('st-multilabel').checked ? '' : 'none';
			el('st-shade-wrap').style.display = categorical ? '' : 'none';
			el('st-rule-label-wrap').style.display =
				el<HTMLInputElement>('st-rule').value.trim() !== '' ? '' : 'none';
			el('st-text-pos-wrap').style.display =
				el<HTMLInputElement>('st-text').value.trim() !== '' ? '' : 'none';
		}

		// ------------------------------------------------------------------ code generation

		/** Parse the condition-table rows DSL: `Label: +,-,+` per line -> Python dict entries. */
		function parseRows(): string[] {
			const entries: string[] = [];
			for (const raw of el<HTMLTextAreaElement>('st-rows').value.split('\n')) {
				const line = raw.trim();
				if (!line) continue;
				const i = line.indexOf(':');
				if (i < 0) continue;
				const label = line.slice(0, i).trim();
				const vals = line
					.slice(i + 1)
					.split(',')
					.map((v) => v.trim())
					.map((v) => (v === '+' ? 'True' : v === '-' ? 'False' : q(v)));
				entries.push(`${q(label)}: [${vals.join(', ')}]`);
			}
			return entries;
		}

		function buildCode(): string {
			const type = el<HTMLSelectElement>('st-type').value;
			const x = el<HTMLSelectElement>('st-x').value;
			const y = el<HTMLSelectElement>('st-y').value;
			const color = el<HTMLSelectElement>('st-color').value;
			// A quantitative color must encode :Q (a gradient legend) - :N would explode every
			// distinct value into its own nominal legend symbol.
			const colorKind = columns.find((c) => c.name === color)?.kind;
			const colorType = colorKind === 'quantitative' ? 'Q' : colorKind === 'temporal' ? 'T' : 'N';
			const xtype = el<HTMLSelectElement>('st-xtype').value;
			const transform = el<HTMLSelectElement>('st-transform').value;
			const categorical = isCategorical();
			const groupComparisons = type === 'strip' || type === 'violin' || type === 'boxplot';

			// theme args
			const t: string[] = [];
			const pal = el<HTMLSelectElement>('st-palette').value;
			if (pal) t.push(`palette=${q(pal)}`);
			const w = +el<HTMLInputElement>('st-w').value;
			const h = +el<HTMLInputElement>('st-h').value;
			if (w !== 100) t.push(`chartWidth=${w}`);
			if (h !== 100) t.push(`chartHeight=${h}`);
			const axisOffset = el<HTMLInputElement>('st-axisoffset').value.trim();
			if (axisOffset !== '') t.push(`axisOffset=${+axisOffset}`);
			const xangle = +el<HTMLInputElement>('st-xangle').value;
			if (xangle !== 0) t.push(`xLabelAngle=${xangle}`);
			if (!el<HTMLInputElement>('st-legend').checked) t.push('legend=False');
			if (el<HTMLInputElement>('st-closed').checked) t.push('closed=True');
			if (el<HTMLInputElement>('st-grid').checked) t.push('grid=True');
			if (el<HTMLInputElement>('st-corner').checked) t.push('cornerRadius=True');

			const reader =
				fileFormat === 'json'
					? `pl.read_json(${q(fileName)})`
					: fileFormat === 'tsv'
						? `pl.read_csv(${q(fileName)}, separator="\\t")`
						: `pl.read_csv(${q(fileName)})`;

			const test = groupComparisons ? el<HTMLSelectElement>('st-test').value : '';
			const omnibus = test === 'kruskal' || test === 'anova';
			const wantsBrackets = Boolean(test) && (!omnibus || el<HTMLSelectElement>('st-brackets').value === 'all');

			const head = ['import altair as alt', 'import polars as pl', 'import dysonsphere as ds'];
			if (wantsBrackets) head.unshift('from itertools import combinations');
			head.push('', `ds.theme(${t.join(', ')})`, '', `df = ${reader}`);

			const body: string[] = [];
			const needCategories =
				categorical &&
				(type === 'strip' ||
					type === 'violin' ||
					Boolean(test) ||
					el<HTMLInputElement>('st-multilabel').checked ||
					el<HTMLInputElement>('st-shade').checked);
			if (needCategories) {
				// sorted() matches the band order Vega-Lite renders for composed charts.
				body.push(`categories = sorted(df[${q(x)}].unique().to_list())`);
			}

			if (type === 'strip') {
				const opts: string[] = [];
				const scatter = el<HTMLSelectElement>('st-scatter').value;
				if (scatter !== 'jitter') opts.push(`scatter=${q(scatter)}`);
				if (!el<HTMLInputElement>('st-errorbars').checked) opts.push('errorbars=False');
				else if (el<HTMLSelectElement>('st-extent').value !== 'sem')
					opts.push(`errorbarExtent=${q(el<HTMLSelectElement>('st-extent').value)}`);
				const extra = opts.length ? `, ${opts.join(', ')}` : '';
				body.push(`chart = ds.mark_strip(df, ${q(x)}, ${q(y)}, categories${extra})`);
			} else if (type === 'violin') {
				body.push(`chart = ds.mark_violin(df, ${q(x)}, ${q(y)}, categories)`);
			} else if (type === 'point' && xtype === 'N' && transform) {
				const off = transform === 'jitter' ? 'jitter_x' : 'beeswarm_x';
				const call =
					transform === 'jitter'
						? `df = ds.add_jitter(df)`
						: `df = ds.add_beeswarm(df, ${q(y)}, groupBy=[${q(x)}])`;
				const enc = [
					`        x=alt.X("${x}:N", title=None),`,
					`        y=alt.Y("${y}:Q"),`,
					`        xOffset=alt.XOffset("${off}:Q"),`,
				];
				if (color) enc.push(`        color=alt.Color("${color}:${colorType}"),`);
				body.push(
					call,
					`chart = (`,
					`    alt.Chart(df)`,
					`    .mark_circle()`,
					`    .encode(`,
					...enc,
					`    )`,
					`)`,
				);
			} else {
				const marks: Record<string, string> = {
					point: 'mark_point',
					bar: 'mark_bar',
					line: 'mark_line',
					boxplot: 'mark_boxplot',
				};
				const yt = type === 'bar' ? `mean(${y})` : y;
				const enc = [
					`        x=alt.X("${x}:${type === 'boxplot' ? 'N' : xtype}"),`,
					`        y=alt.Y("${yt}:Q"),`,
				];
				if (color && type !== 'boxplot') enc.push(`        color=alt.Color("${color}:${colorType}"),`);
				body.push(`chart = (`, `    alt.Chart(df)`, `    .${marks[type]}()`, `    .encode(`, ...enc, `    )`, `)`);
			}

			// Layers compose with + : shade under, statistics/rules/text over, multilabel wraps.
			if (categorical && el<HTMLInputElement>('st-shade').checked) {
				body.push('', `chart = ds.add_shade(categories=categories) + chart`);
			}
			const shadeLo = el<HTMLInputElement>('st-shade-lo').value.trim();
			const shadeHi = el<HTMLInputElement>('st-shade-hi').value.trim();
			if (shadeLo !== '' && shadeHi !== '') {
				body.push('', `chart = ds.add_shade(positions=[(${+shadeLo}, ${+shadeHi})], axis="y") + chart`);
			}

			if (type === 'point' && xtype === 'Q') {
				const method = el<HTMLSelectElement>('st-correlation').value;
				if (method) {
					const opts = [`method=${q(method)}`];
					if (el<HTMLInputElement>('st-corr-verbose').checked) opts.push('verbose=True');
					body.push('', `chart = chart + ds.add_correlation(df, ${q(x)}, ${q(y)}, ${opts.join(', ')})`);
				}
			}

			if (test) {
				const opts = [`test=${q(test)}`, `categories=categories`];
				const labelStyle = el<HTMLSelectElement>('st-labelstyle').value;
				if (labelStyle !== 'p') opts.push(`labelStyle=${q(labelStyle)}`);
				if (wantsBrackets) {
					body.push('', `pairs = list(combinations(categories, 2))`);
					body.push(`chart = chart + ds.add_comparisons(df, ${q(x)}, ${q(y)}, pairs, ${opts.join(', ')})`);
				} else {
					body.push('', `chart = chart + ds.add_comparisons(df, ${q(x)}, ${q(y)}, ${opts.join(', ')})`);
				}
			}

			const rule = el<HTMLInputElement>('st-rule').value.trim();
			if (rule !== '') {
				const label = el<HTMLInputElement>('st-rule-label').value.trim();
				const labelArg = label ? `, label=${q(label)}` : '';
				body.push('', `chart = chart + ds.add_rule(${+rule}${labelArg})`);
			}

			const textNote = el<HTMLInputElement>('st-text').value.trim();
			if (textNote !== '') {
				const pos = el<HTMLSelectElement>('st-text-pos').value;
				body.push('', `chart = chart + ds.add_text(${q(textNote)}, position=${q(pos)})`);
			}

			if (categorical && el<HTMLInputElement>('st-multilabel').checked) {
				const rows = parseRows();
				const opts: string[] = [];
				if (el<HTMLInputElement>('st-samplesize').checked)
					opts.push(`showSampleSize=True`, `df=df`, `xCol=${q(x)}`);
				if (el<HTMLInputElement>('st-catlabels').checked) opts.push('categoryLabel=True');
				body.push(
					'',
					`chart = ds.add_multilabel(`,
					`    chart,`,
					`    groups={${rows.join(', ')}},`,
					`    categories=categories,`,
					...opts.map((o) => `    ${o},`),
					`)`,
				);
			}

			return [...head, '', ...body].join('\n');
		}

		// ------------------------------------------------------------------ rendering

		function syncPalettePreview() {
			const name = el<HTMLSelectElement>('st-palette').value;
			const colors = PALETTE_COLORS[name];
			const preview = el('st-palette-preview');
			preview.innerHTML = '';
			if (!colors) return;
			for (const c of colors) {
				const stop = document.createElement('span');
				stop.style.background = c;
				preview.appendChild(stop);
			}
		}

		// Fit the render to the panel: the site-wide 3.5x chart zoom overflows once a legend
		// or a wide canvas grows the chart - cap the zoom so the whole figure stays in view.
		function fitChartZoom() {
			const svg = chartEl.querySelector('svg');
			const natural = svg ? parseFloat(svg.getAttribute('width') ?? '0') : 0;
			if (natural <= 0) return;
			// Measure the PARENT panel: the chart div itself is (re)classed .vega-embed and can
			// shrink-wrap its zoomed content, so its own size follows the thing being fitted.
			const panel = chartEl.parentElement?.getBoundingClientRect().width ?? 0;
			const avail = panel - 34; // chart padding + panel border
			if (avail <= 0) return;
			const z = Math.min(3.5, Math.max(1, avail / natural));
			chartEl.style.setProperty('--ds-chart-zoom', z.toFixed(3));
		}
		new ResizeObserver(() => fitChartZoom()).observe(chartEl);

		async function renderSpec(code: string) {
			if (!runtime) return;
			setStatus('Rendering…');
			try {
				const spec = JSON.parse(runtime.runChart(code, isDark()));
				await vegaEmbed(chartEl, spec, { actions: true, renderer: 'svg', background: 'transparent' });
				alignGridToContent(chartEl, spec);
				fixSuperscripts(chartEl);
				italicizeStatSymbols(chartEl);
				fitChartZoom();
				clearError();
				setStatus('', 'ok');
			} catch (e) {
				setStatus('Error', 'err');
				showError(e);
				console.error(e);
			}
		}

		let renderTimer: number | undefined;
		async function renderBuild() {
			if (mode !== 'build') return; // a queued render must never clobber code-mode output
			const code = buildCode();
			setBuilderCode(code);
			syncPalettePreview();
			if (!runtime || !columns.length) return;
			await renderSpec(code);
		}
		function scheduleRender() {
			if (mode !== 'build') return;
			window.clearTimeout(renderTimer);
			renderTimer = window.setTimeout(renderBuild, 150);
		}
		async function runCode() {
			await renderSpec(editor.state.doc.toString());
		}
		function rerenderCurrent() {
			if (mode === 'build') scheduleRender();
			else runCode();
		}

		function applySchema(infoJson: string, name: string, format: 'csv' | 'tsv' | 'json') {
			const info = JSON.parse(infoJson);
			fileName = name;
			fileFormat = format;
			columns = info.columns;
			dataInfo.textContent = `${name} · ${info.rows} rows · ${columns.length} columns`;
			fillSelect('st-x');
			fillSelect('st-y', false, 'quantitative'); // Y is always the measured value
			fillSelect('st-color', true);
			seedEncodings();
			syncVisibility();
			if (mode === 'build') renderBuild();
		}

		async function loadTable(text: string, name: string, format: 'csv' | 'tsv' | 'json') {
			if (!runtime) return;
			try {
				applySchema(runtime.loadTable(name, text, format), name, format);
			} catch (e) {
				dataInfo.textContent = 'Could not parse that file.';
				showError(e);
				console.error(e);
			}
		}

		// ------------------------------------------------------------------ export import

		/** Last line of a Python traceback - the informative part for inline hints. */
		const pyMessage = (e: unknown) =>
			String((e as Error)?.message ?? e)
				.trimEnd()
				.split('\n')
				.pop() ?? '';

		function showMeta(name: string, meta: Record<string, unknown> | null, error?: string) {
			el('st-meta-title').textContent = `Export metadata - ${name}`;
			const report = meta?.report
				? Object.values(meta.report as Record<string, string>).join('\n\n')
				: '';
			el('st-meta-report').textContent = report || error || '(no embedded report)';
			el('st-meta-json').textContent = meta ? JSON.stringify(meta, null, 2) : '';
			el('st-meta-panel').hidden = false;
		}

		// A file saved by ds.save(): a JSON spec rebuilds the chart through ds.load() (run in
		// the code editor, so the shown snippet is exactly what executed); JSON, SVG, and PNG
		// all surface their embedded dysonsphere block via ds.read().
		async function importExport(file: File) {
			const rt = runtime ?? (await getRuntime());
			runtime = rt;
			const bytes = new Uint8Array(await file.arrayBuffer());
			rt.writeFile(file.name, bytes);
			clearError();
			el('st-meta-panel').hidden = true;
			const ext = file.name.split('.').pop()?.toLowerCase();
			if (ext === 'json') {
				let parsed: Record<string, unknown> | null = null;
				try {
					parsed = JSON.parse(new TextDecoder().decode(bytes));
				} catch {
					/* not JSON after all - fall through to the metadata attempt */
				}
				const isSpec =
					parsed &&
					!Array.isArray(parsed) &&
					['$schema', 'mark', 'layer', 'encoding', 'vconcat', 'hconcat', 'concat'].some(
						(k) => k in parsed,
					);
				if (isSpec) {
					setMode(
						'code',
						[
							'import dysonsphere as ds',
							'',
							'# Rebuild the exported chart: ds.load() re-applies the theme baked into the file.',
							`chart = ds.load(${q(file.name)})`,
						].join('\n'),
					);
					await runCode();
				} else if (parsed) {
					showError(
						new Error(`${file.name} looks like a data table, not a chart export - use the Data upload above.`),
					);
					return;
				}
			}
			try {
				showMeta(file.name, JSON.parse(rt.readExport(file.name)));
			} catch (e) {
				showMeta(file.name, null, pyMessage(e));
			}
		}

		// ------------------------------------------------------------------ wiring

		root
			.querySelectorAll('.st__controls select, .st__controls input, .st__controls textarea')
			.forEach((node) => {
				// The export importer and the dataset loader run their own async flows - a builder
				// re-render here would race them and paint the old chart back over the result.
				if (['st-export-file', 'st-dataset'].includes((node as HTMLElement).id)) return;
				node.addEventListener('change', () => {
					if ((node as HTMLElement).id === 'st-x') syncXType();
					syncVisibility();
					scheduleRender();
				});
				node.addEventListener('input', () => {
					syncVisibility();
					scheduleRender();
				});
			});

		el('st-file').addEventListener('change', (ev) => {
			const file = (ev.target as HTMLInputElement).files?.[0];
			if (!file) return;
			const ext = file.name.split('.').pop()?.toLowerCase();
			const format = (ext === 'json' ? 'json' : ext === 'tsv' ? 'tsv' : 'csv') as 'csv' | 'tsv' | 'json';
			file.text().then((text) => loadTable(text, file.name, format));
		});
		el('st-dataset').addEventListener('change', async () => {
			const name = el<HTMLSelectElement>('st-dataset').value;
			if (!name) return;
			if (name === 'sample') return loadTable(SAMPLE, 'sample.csv', 'csv');
			const rt = runtime ?? (await getRuntime());
			runtime = rt;
			try {
				applySchema(rt.loadDataset(name), `${name}.csv`, 'csv');
			} catch (e) {
				dataInfo.textContent = `Could not load ${name}.`;
				showError(e);
				console.error(e);
			}
		});
		el('st-export-file').addEventListener('change', (ev) => {
			const file = (ev.target as HTMLInputElement).files?.[0];
			if (file) importExport(file);
		});
		el('st-meta-close').addEventListener('click', () => {
			el('st-meta-panel').hidden = true;
		});
		el('st-copy').addEventListener('click', () => {
			const text = (mode === 'code' ? editor : builderView).state.doc.toString();
			navigator.clipboard?.writeText(text);
			const b = el('st-copy');
			b.textContent = 'Copied!';
			setTimeout(() => (b.textContent = 'Copy'), 900);
		});
		el('st-edit').addEventListener('click', () => setMode('code', buildCode()));
		el('st-back').addEventListener('click', () => {
			setMode('build');
			scheduleRender();
		});
		el('st-run').addEventListener('click', runCode);

		// Site theme toggle: re-render the current chart with inverted ink; also swap the
		// editor's syntax theme.
		new MutationObserver(() => {
			editor.dispatch({ effects: themeCompartment.reconfigure(cmTheme()) });
			builderView.dispatch({ effects: builderThemeCompartment.reconfigure(cmTheme()) });
			rerenderCurrent();
		}).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

		// A new #code= deep link while already on this page replaces the editor and re-runs.
		window.addEventListener('hashchange', () => {
			const code = hashCode();
			if (code === null) return;
			setMode('code', code);
			if (runtime) runCode();
		});

		// Initial state: code mode when deep-linked, builder otherwise. The builder shows its
		// generated snippet immediately; the chart appears once the runtime boots.
		if (mode === 'code') setMode('code');
		else setBuilderCode(buildCode());
		syncVisibility();
		onRuntimeStatus((msg) => {
			if (!runtime) setStatus(msg);
		});
		getRuntime()
			.then(async (rt) => {
				runtime = rt;
				// The dropdown is baked from the checked-out library's palettes.json, but the
				// Studio EXECUTES the PyPI release, which can lag - a palette the runtime lacks
				// passes through as an invalid Vega scheme and the chart silently fails to
				// render. Prune to the installed catalogue so every offered option works.
				const available = new Set(rt.listPalettes());
				for (const opt of [...el<HTMLSelectElement>('st-palette').options]) {
					if (opt.value && !available.has(opt.value)) opt.remove();
				}
				// Default working set: the classic cars dataset as a weight-vs-economy scatter.
				applySchema(rt.loadDataset('cars'), 'cars.csv', 'csv');
				const setSel = (id: string, v: string) => {
					const sel = el<HTMLSelectElement>(id);
					if ([...sel.options].some((o) => o.value === v)) sel.value = v;
				};
				setSel('st-x', 'Miles_per_Gallon');
				setSel('st-y', 'Weight_in_lbs');
				syncXType();
				syncVisibility();
				if (mode === 'build') renderBuild();
				if (mode === 'code') await runCode();
			})
			.catch((e) => {
				setStatus('Boot failed', 'err');
				showError(e);
				console.error(e);
			});
	}

	initStudio();
	document.addEventListener('astro:page-load', initStudio);
</script>

<style>
	.st {
		display: grid;
		grid-template-columns: minmax(30rem, 36rem) minmax(0, 1fr);
		gap: 1.25rem;
