		gap: 1rem;
		/* Stay inside the grid track: without this, a wide (zoomed) chart inflates the item
		   past its column (min-width:auto), the panel clips it, and the fit-zoom measures the
		   inflated width - so the cap never engages. */
		min-width: 0;
	}
	.st__panel {
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.65rem;
		overflow: hidden;
		/* Same track-containment as .st__output: a flex item's min-width:auto floors its
		   stretched width at the (zoomed) content's min-content size. */
